# Restreaming Automation – Environment Configuration
# Copy this to .env and fill in values.

# --- Streaming app ---
# "obs" (OBS Studio) or "streamlabs" (Streamlabs Desktop).
# Can also be switched at runtime from the dashboard (which overrides this).
STREAMING_APP=obs

# --- OBS WebSocket (when STREAMING_APP=obs) ---
OBS_WS_HOST=127.0.0.1
OBS_WS_PORT=4455
OBS_WS_PASSWORD=change_me_please

# --- Streamlabs Desktop (when STREAMING_APP=streamlabs) ---
# In Streamlabs Desktop enable Settings -> Mobile -> "Allow third party
# connections"; copy the API Token shown there. Can also be set from the dashboard.
# SLOBS_HOST=127.0.0.1
# SLOBS_PORT=59650
# SLOBS_TOKEN=

# --- Ingest ---
# Base port for UDP ingest streams. Racer 1 → BASE, Racer 2 → BASE+1, etc.
INGEST_BASE_PORT=1234
INGEST_PROTOCOL=udp
# Set to "srt" for SRT ingest instead of UDP

# Twitch OAuth token — authenticates streamlink to bypass ads.
# Get one from your browser's developer console while logged into Twitch with the following command:
#  document.cookie.split("; ").find(item=>item.startsWith("auth-token"))?.split("=")[1]
# Can also be set at runtime via the dashboard or POST /api/ingest/token.
# TWITCH_OAUTH_TOKEN=

# --- Server ---
API_HOST=0.0.0.0
API_PORT=8008

# --- Docker ---
# When running in Docker, set this to the OBS data directory on the HOST
# so that image-source paths are translated correctly.
# OBS_DATA_DIR=/app/data
